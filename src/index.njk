<!-- Featured Work -->
<section class="section" aria-label="Featured Work">
  <div class="container">
    <h2 class="section-heading">What I've Built</h2>

    <div class="grid grid--3 stagger">
      <article class="card card--link">
        <span class="card__eyebrow">Venture · AI Platform</span>
        <h3 class="card__title"><a href="/cocovox/">Cocovox</a></h3>
        <p class="card__description">
          AI learning platform with adaptive tutoring, literacy-first lessons, and AAC communication tools — built from the ground up around accessibility and real-time speech feedback.
        </p>
        <p class="card__meta">Seeking early-stage partners</p>
      </article>

      <article class="card card--link">
        <span class="card__eyebrow">Patent · Generative AI</span>
        <h3 class="card__title"><a href="/portfolio/#patent">AI Content Pipeline</a></h3>
        <p class="card__description">
          US Patent for a spanning content tree system — a generative AI architecture for structured content creation and network automation. Published 2025.
        </p>
      </article>

      <article class="card card--link">
        <span class="card__eyebrow">Role · AI Strategy</span>
        <h3 class="card__title"><a href="/portfolio/#cisco">Cisco AI Leadership</a></h3>
        <p class="card__description">
          Leading AI solutions for 400K+ SMB customers, mentoring cross-functional teams, and standing up Cisco's LLM Center of Excellence for support engineering.
        </p>
      </article>
    </div>
  </div>
</section>

<!-- Services -->
