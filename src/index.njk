</section>

<!-- Latest Writing -->
<section class="section" aria-label="Latest writing">
  <div class="container container--narrow">
    <h2 class="section-heading">Latest Writing</h2>

    <div class="stagger">
      {%- set posts = collections.posts | head(3) %}
      {%- for post in posts %}
      <article class="post-card">
        <div class="post-card__meta">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          <span>{{ post.content | readingTime }}</span>
        </div>
        <h3 class="post-card__title">
          <a href="{{ post.url }}" style="view-transition-name: post-title-{{ post.fileSlug }};">{{ post.data.title }}</a>
        </h3>
        {% if post.data.excerpt %}
        <p class="post-card__excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
      </article>
      {%- endfor %}
    </div>

    {% if collections.posts | length > 3 %}
    <div class="section__cta">
      <a href="/blog/" class="btn btn--secondary">View All Posts</a>
    </div>
    {% endif %}
  </div>
</section>

<!-- About CTA -->
<section class="section" aria-label="About">
  <div class="container container--narrow section__centered">
    <h2 class="section-heading">A Little About Me</h2>
    <p class="section-subtitle">
      I spent a decade in NYC's ad tech scene building products at the intersection of technology and creative storytelling. Now I lead AI strategy at Cisco and I'm channeling everything I've learned into Cocovox — because 2 in 3 kids can't read at grade level and that's not okay.
    </p>
    <div class="section__cta">
      <a href="/about/" class="btn btn--primary">Read My Full Story</a>
    </div>
  </div>
</section>
