---
layout: base.njk
---
<article class="post" style="view-transition-name: post-{{ page.fileSlug }};">
  <header class="post-header">
    <h1 class="post-title" style="view-transition-name: post-title-{{ page.fileSlug }};">{{ title }}</h1>
    <div class="post-meta">
      <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>
      <span class="reading-time">{{ content | readingTime }}</span>
    </div>
    {% if tags %}
    <div class="post-tags">
      {%- for tag in tags %}
      {% if tag != "post" %}<span class="tag">{{ tag }}</span>{% endif %}
      {%- endfor %}
    </div>
    {% endif %}
  </header>

  <div class="prose">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <div class="author-card">
      <div class="author-info">
        <strong>{{ site.author.name }}</strong>
        <p>{{ site.tagline }}</p>
      </div>
    </div>
    <a href="/blog/" class="back-link">&larr; All posts</a>
  </footer>
</article>
