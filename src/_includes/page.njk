---
layout: base.njk
---
<article class="page-content" style="view-transition-name: page-content;">
  <header class="page-header">
    <h1 class="page-title" style="view-transition-name: page-title;">{{ title }}</h1>
    {% if subtitle %}<p class="page-subtitle">{{ subtitle }}</p>{% endif %}
  </header>
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
